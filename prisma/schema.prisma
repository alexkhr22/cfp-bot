generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int              @id @default(autoincrement())
  name      String
  tags      String[]
  groups    UserKeywordGroup[]
  cfps      CFP[]
}

model KeywordGroup {
  id        Int              @id @default(autoincrement())
  name      String
  keywords  String[]
  users     UserKeywordGroup[]
  cfps      CFPKeywordGroup[]
}

model CFP {
  id                 Int      @id @default(autoincrement())
  title              String
  deadline           DateTime
  location           String?
  conferenceDate     DateTime
  url                String
  callback           DateTime
  submissionForm     SubmissionForm
  wordCharacterLimit Int?
  tag                String?

  userId             Int
  user               User     @relation(fields: [userId], references: [id])

  groups             CFPKeywordGroup[]
}

model UserKeywordGroup {
  userId  Int
  groupId Int

  user    User         @relation(fields: [userId], references: [id])
  group   KeywordGroup @relation(fields: [groupId], references: [id])

  @@id([userId, groupId])
}

model CFPKeywordGroup {
  cfpId   Int
  groupId Int

  cfp     CFP          @relation(fields: [cfpId], references: [id])
  group   KeywordGroup @relation(fields: [groupId], references: [id])

  @@id([cfpId, groupId])
}

enum SubmissionForm {
  PDF
  EASYCHAIR
  OPENREVIEW
  OTHER
}
