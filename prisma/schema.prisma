generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int              @id @default(autoincrement())
  name      String
  tags      String[]
  groups    UserKeywordGroup[]
  cfps      CFP[]
}

model KeywordGroup {
  id        Int              @id @default(autoincrement())
  name      String
  keywords  String[]
  users     UserKeywordGroup[]
  cfps      CFPKeywordGroup[]
}

model CFP {
  id                 Int      @id @default(autoincrement())
  
  title              String?
  deadline           String?
  location           String?
  conferenceDate     String?
  url                String?
  submissionForm     String?
  wordCharacterLimit String?
  tags               String[]
  note               String?

  userId             Int
  user               User     @relation(fields: [userId], references: [id])

  groups             CFPKeywordGroup[]

  @@unique([url, title, conferenceDate])
}

model UserKeywordGroup {
  userId  Int
  groupId Int

  user    User         @relation(fields: [userId], references: [id])
  group   KeywordGroup @relation(fields: [groupId], references: [id])

  @@id([userId, groupId])
}

model CFPKeywordGroup {
  cfpId   Int
  groupId Int

  cfp     CFP          @relation(fields: [cfpId], references: [id])
  group   KeywordGroup @relation(fields: [groupId], references: [id])

  @@id([cfpId, groupId])
}

enum SubmissionForm {
  PDF
  EASYCHAIR
  OPENREVIEW
  OTHER
}
